# ============================================================
# PerformanceAI — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env no repositório.
#
# Para deploy na Vercel:
# Acesse: Project Settings → Environment Variables
# e adicione as variáveis abaixo.
# ============================================================

# URL do projeto Supabase
# Encontre em: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave pública (anon) do Supabase
# Encontre em: Supabase Dashboard → Project Settings → API → anon public
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
